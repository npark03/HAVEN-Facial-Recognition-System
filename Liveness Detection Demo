source":["with open(METADATA_FILE, \"r\") as f:\n","    metadata = json.load(f)\n","\n","face_detector = cv2.CascadeClassifier(CASCADE_PATH)\n","\n","if face_detector.empty():\n","    raise RuntimeError(f\"Could not load Haar cascade: {CASCADE_PATH}\")"],"metadata":{"id":"srHoBo5zW5Af","executionInfo":{"status":"ok","timestamp":1776411194221,"user_tz":240,"elapsed":1144,"user":{"displayName":"Jeremiah Poggers","userId":"12070734939999147503"}}},"execution_count":5,"outputs":[]},{"cell_type":"code","source":["def show_image(title, image_bgr, figsize=(6,6)):\n","    image_rgb = cv2.cvtColor(image_bgr, cv2.COLOR_BGR2RGB)\n","    plt.figure(figsize=figsize)\n","    plt.imshow(image_rgb)\n","    plt.title(title)\n","    plt.axis(\"off\")\n","    plt.show()\n","\n","\n","def detect_largest_face_box(image_bgr):\n","    gray = cv2.cvtColor(image_bgr, cv2.COLOR_BGR2GRAY)\n","\n","    faces = face_detector.detectMultiScale(\n","        gray,\n","        scaleFactor=1.1,\n","        minNeighbors=5,\n","        minSize=(80, 80)\n","    )\n","\n","    if len(faces) == 0:\n","        return None\n","\n","    faces = sorted(faces, key=lambda f: f[2] * f[3], reverse=True)\n","    return faces[0]\n","\n","\n","def draw_face_box(image_bgr, face_box, color=(0, 255, 0)):\n","    boxed = image_bgr.copy()\n","    x, y, w, h = face_box\n","    cv2.rectangle(boxed, (x, y), (x + w, y + h), color, 3)\n","    return boxed\n","\n","\n","def face_center(face_box):\n","    x, y, w, h = face_box\n","    return (x + w / 2.0, y + h / 2.0)\n","\n","\n","def draw_center(image_bgr, center, color=(255, 0, 0)):\n","    marked = image_bgr.copy()\n","    cx, cy = int(center[0]), int(center[1])\n","    cv2.circle(marked, (cx, cy), 8, color, -1)\n","    return marked"],"metadata":{"id":"6S2LUWDzW7HH","executionInfo":{"status":"ok","timestamp":1776411199910,"user_tz":240,"elapsed":17,"user":{"displayName":"Jeremiah Poggers","userId":"12070734939999147503"}}},"execution_count":6,"outputs":[]},{"cell_type":"co