ts":[]},{"cell_type":"code","source":["SESSION_SUBDIR = \"normal\""],"metadata":{"id":"3ncaQvgmr34i","executionInfo":{"status":"ok","timestamp":1776417633214,"user_tz":240,"elapsed":32,"user":{"displayName":"Jeremiah Poggers","userId":"12070734939999147503"}}},"execution_count":16,"outputs":[]},{"cell_type":"code","source":["# ============================================================\n","# LBPH + Bounding-Box Liveness Evaluation for Dataset Rounds\n","# Google Colab - One Cell Version\n","# Mirrors the Raspberry Pi run_liveness_check_lbph.py logic\n","# ============================================================\n","\n","!pip install -q opencv-contrib-python-headless pandas\n","\n","import json\n","import cv2\n","import numpy as np\n","import pandas as pd\n","from pathlib import Path\n","from google.colab import drive\n","\n","# -----------------------------\n","# 1. Mount Google Drive\n","# -----------------------------\n","drive.mount('/content/drive')\n","\n","# -----------------------------\n","# 2. CONFIG\n","# -----------------------------\n","BASE_DIR = Path(\"/content/drive/MyDrive/Capstone\")\n","\n","# Folder of Nathan training images\n","TRAIN_DIR = BASE_DIR / \"dataset\" / \"nathan\"\n","\n","# Folder to evaluate: change to \"normal\", \"dark\", or \"glasses\"\n","SESSION_DIR = BASE_DIR / \"dataset\" / SESSION_SUBDIR\n","\n","# Metadata file for the chosen dataset folder\n","METADATA_FILE = SESSION_DIR / \"metadata.json\"\n","\n","# Output paths\n","OUTPUT_CSV = SESSION_DIR / f\"lbph_liveness_{SESSION_SUBDIR}_results.csv\"\n","OUTPUT_JSON = SESSION_DIR / f\"lbph_liveness_{SESSION_SUBDIR}_results.json\"\n","\n","# LBPH model output paths\n","MODEL_DIR = BASE_DIR / \"model\" / \"lbph\"\n","MODEL_DIR.mkdir(parents=True, exist_ok=True)\n","\n","TRAINER_FILE = MODEL_DIR / \"trainer.yml\"\n","LABELS_FILE = MODEL_DIR / \"labels.json\"\n","\n","# Haar cascade\n","CASCADE_PATH = cv2.data.haarcascades + \"haarcascade_frontalface_default.xml\"\n","\n","# Same style of thresholds as your Pi file\n","# Lower these if you want easier liveness passing\n","HORIZONTAL_THRESHOLD = 18\n","VERTICAL_THRESHOLD = 10\n","\n","# LBPH confidence threshold: lower is better\n","LBPH_CONFIDENCE_THRESHOLD = 70.0\n","\n","# Whether both images must contain a face\n","REQUIRE_FACE_IN_BOTH = True\n","\n","# -----------------------------\n","# 3. Load detector\n","# -----------------------------\n","face_detector = cv2.CascadeClassifier(CASCADE_PATH)\n","if face_detector.empty():\n","    raise RuntimeError(f\"Could not load Haar cascade: {CASCADE_PATH}\")\n","\n","# -----------------------------\n","# 4. Helper functions\n","# -----------------------------\n","def detect_largest_face_box(image_bgr):\n","    gray = cv2.cvtColor(image_bgr, cv2.COLOR_BGR2GRAY)\n","\n","    faces = face_detector.detectMultiScale(\n","        gray,\n","        scaleFactor=1.1,\n","        minNeighbors=5,\n","        minSize=(80, 80)\n","    )\n","\n","    if len(faces) == 0:\n","        return None\n","\n","    faces = sorted(faces, key=lambda f: f[2] * f[3], reverse=True)\n","    return faces[0]\n","\n","\n","def face_center(face_box):\n","    x, y, w, h = face_box\n","    return (x + w / 2.0, y + h / 2.0)\n","\n","\n","def check_liveness(challenge, box1, box2):\n","    c1 = face_center(box1)\n","    c2 = face_center(box2)\n","\n","    dx = c2[0] - c1[0]\n","    dy = c2[1] - c1[1]\n","\n","    if challenge == \"LOOK_LEFT\":\n","        passed = dx <= -HORIZONTAL_THRESHOLD\n","    elif challenge == \"LOOK_RIGHT\":\n","        passed = dx >= HORIZONTAL_THRESHOLD\n","    elif challenge == \"LOOK_UP\":\n","        passed = dy <= -VERTICAL_THRESHOLD\n","    else:\n","        passed = False\n","\n","    debug = {\n","        \"movement_x\": round(float(dx), 2),\n","        \"movement_y\": round(float(dy), 2),\n","        \"face1_center\": [round(float(c1[0]), 2), round(float(c1[1]), 2)],\n","        \"face2_center\": [round(float(c2[0]), 2), round(float(c2[1]), 2)],\n","    }\n","\n","    return passed, debug\n","\n","\n","def crop_face(gray_image, face_box, padding=0.15):\n","    x, y, w, h = face_box\n","    img_h, img_w = gray_image.shape[:2]\n","\n","    pad_w = int(w * padding)\n","    pad_h = int(h * padding)\n","\n","    x1 = max(0, x - pad_w)\n","    y1 = max(0, y - pad_h)\n","    x2 = min(img_w, x + w + pad_w)\n","    y2 = min(img_h, y + h + pad_h)\n","\n","    face = gray_image[y1:y2, x1:x2]\n","    if face.size == 0:\n","        raise ValueError(\"Face crop was empty\")\n","\n","    face = cv2.resize(face, (200, 200))\n","    return face\n","\n","\n","def resolve_to_session_file(image_path_str):\n","    # Metadata may contain Raspberry Pi absolute paths.\n","    # This maps them to the current Colab dataset folder by filename.\n","    return SESSION_DIR / Path(image_path_str).name\n","\n","\n","# -----------------------------\n","# 6. Authorization function\n","# -----------------------------\n","def authorize_first_image(image_bgr):\n","    gray = cv2.cvtColor(image_bgr, cv2.COLOR_BGR2GRAY)\n","\n","    face_box = detect_largest_face_box(image_bgr)\n","    if face_box is None:\n","        return {\n","            \"authorized\": False,\n","            \"reason\": \"no_face_for_authorization\",\n","            \"identity\": None,\n","            \"confidence\": None,\n","            \"predicted_label_id\": None,\n","            \"threshold\": LBPH_CONFIDENCE_THRESHOLD,\n","        }\n","\n","    face = crop_face(gray, face_box)\n","    label_id, confidence = recognizer.predict(face)\n","\n","    identity = labels.get(str(label_id), \"unknown\")\n","    authorized = confidence <= LBPH_CONFIDENCE_THRESHOLD\n","\n","    return {\n","        \"authorized\": bool(authorized),\n","        \"reason\": \"ok\" if authorized else \"face_not_recognized\",\n","        \"identity\": identity if authorized else \"unknown\",\n","        \"predicted_label_id\": int(label_id),\n","        \"confidence\": round(float(confidence), 4),\n","        \"threshold\": LBPH_CONFIDENCE_THRESHOLD,\n","    }\n","\n","# -----------------------------\n","# 7. Load metadata\n","# -----------------------------\n","with open(METADATA_FILE, \"r\") as f:\n","    metadata = json.load(f)\n","\n","rounds = metadata[\"rounds\"]\n","\n","# -----------------------------\n","# 8. Evaluate all rounds\n","# -----------------------------\n","all_results = []\n","\n","for item in rounds:\n","    round_num = item.get(\"round\")\n","    challenge = item.get(\"challenge\")\n","    image1_path_str = item.get(\"image_1\")\n","    image2_path_str = item.get(\"image_2\")\n","\n","    if not image1_path_str or not image2_path_str:\n","        all_results.append({\n","            \"round\": round_num,\n","            \"challenge\": challenge,\n","            \"image_1\": image1_path_str,\n","            \"image_2\": image2_path_str,\n","            \"face_detected_img1\": False,\n","            \"face_detected_img2\": False,\n","            \"liveness_passed\": False,\n","            \"authorized\": False,\n","            \"identity\": None,\n","            \"confidence\": None,\n","            \"reason\": \"missing_image_path\",\n","            \"movement_x\": None,\n","            \"movement_y\": None\n","        })\n","        continue\n","\n","    img1_path = resolve_to_session_file(image1_path_str)\n","    img2_path = resolve_to_session_file(image2_path_str)\n","\n","    img1 = cv2.imread(str(img1_path))\n","    img2 = cv2.imread(str(img2_path))\n","\n","    if img1 is None or img2 is None:\n","        all_results.append({\n","            \"round\": round_num,\n","            \"challenge\": challenge,\n","            \"image_1\": str(img1_path),\n","            \"image_2\": str(img2_path),\n","            \"face_detected_img1\": False,\n","            \"face_detected_img2\": False,\n","            \"liveness_passed\": False,\n","            \"authorized\": False,\n","            \"identity\": None,\n","            \"confidence\": None,\n","            \"reason\": \"could_not_read_image\",\n","            \"movement_x\": None,\n","            \"movement_y\": None\n","        })\n","        continue\n","\n","    box1 = detect_largest_face_box(img1)\n","    box2 = detect_largest_face_box(img2)\n","\n","    face1 = box1 is not None\n","    face2 = box2 is not None\n","\n","    if REQUIRE_FACE_IN_BOTH and (not face1 or not face2):\n","        all_results.append({\n","            \"round\": round_num,\n","            \"challenge\": challenge,\n","            \"image_1\": str(img1_path),\n","            \"image_2\": str(img2_path),\n","            \"face_detected_img1\": face1,\n","            \"face_detected_img2\": face2,\n","            \"liveness_passed\": False,\n","            \"authorized\": False,\n","            \"identity\": None,\n","            \"confidence\": None,\n","            \"reason\": \"no_face_detected_in_one_or_both_images\",\n","            \"movement_x\": None,\n","            \"movement_y\": None\n","        })\n","        continue\n","\n","    liveness_passed, debug = check_liveness(challenge, box1, box2)\n","\n","    if liveness_passed:\n","        auth_result = authorize_first_image(img1)\n","        reason = auth_result[\"reason\"]\n","        authorized = auth_result[\"authorized\"]\n","        identity = auth_result[\"identity\"]\n","        confidence = auth_result[\"confidence\"]\n","        predicted_label_id = auth_result[\"predicted_label_id\"]\n","    else:\n","        reason = \"challenge_failed\"\n","        authorized = False\n","        identity = None\n","        confidence = None\n","        predicted_label_id = None\n","\n","    all_results.append({\n","        \"round\": round_num,\n","        \"challenge\": challenge,\n","        \"image_1\": str(img1_path),\n","        \"image_2\": str(img2_path),\n","        \"face_detected_img1\": face1,\n","        \"face_detected_img2\": face2,\n","        \"liveness_passed\": bool(liveness_passed),\n","        \"au