thresholds for challenge pass/fail\n","YAW_THRESHOLD = 0.035      # left/right movement sensitivity\n","PITCH_UP_THRESHOLD = 0.020 # upward movement sensitivity\n","\n","# optional minimum confidence that a face exists in both images\n","REQUIRE_FACE_IN_BOTH = True\n","\n","# -----------------------------\n","# 3. MediaPipe setup\n","# -----------------------------\n","mp_face_mesh = mp.solutions.face_mesh\n","\n","face_mesh = mp_face_mesh.FaceMesh(\n","    static_image_mode=True,\n","    max_num_faces=1,\n","    refine_landmarks=True,\n","    min_detection_confidence=0.5\n",")\n","\n","# -----------------------------\n","# 4. Landmark helper functions\n","# -----------------------------\n","def load_image_rgb(path):\n","    img_bgr = cv2.imread(path)\n","    if img_bgr is None:\n","        return None\n","    return cv2.cvtColor(img_bgr, cv2.COLOR_BGR2RGB)\n","\n","def get_landmarks(image_rgb):\n","    results = face_mesh.process(image_rgb)\n","    if not results.multi_face_landmarks:\n","        return None\n","\n","    face_landmarks = results.multi_face_landmarks[0]\n","    h, w, _ = image_rgb.shape\n","\n","    pts = []\n","    for lm in face_landmarks.landmark:\n","        pts.append((lm.x * w, lm.y * h))\n","    return np.array(pts, dtype=np.float32)\n","\n","def safe_mean(points):\n","    return np.mean(points, axis=0)\n","\n","def estimate_pose_features(landmarks):\n","    \"\"\"\n","    Lightweight face-pose approximation from facial landmarks.\n","    Returns yaw and pitch style measures using relative landmark geometry.\n","\n","    Landmark groups:\n","      left eye outer area\n","      right eye outer area\n","      nose tip\n","      chin\n","      forehead-ish\n","    \"\"\"\n","\n","    # Mediapipe landmark indices\n","    LEFT_EYE = [33, 133]\n","    RIGHT_EYE = [362, 263]\n","    NOSE_TIP = 1\n","    CHIN = 152\n","    FOREHEAD = 10\n","\n","    left_eye_center = safe_mean(landmarks[LEFT_EYE])\n","    right_eye_center = safe_mean(landmarks[RIGHT_EYE])\n","    nose_tip = landmarks[NOSE_TIP]\n","    chin = landmarks[CHIN]\n","    forehead = landmarks[FOREHEAD]\n","\n","    eye_center = (left_eye_center + right_eye_center) / 2.0\n","    eye_distance = np.linalg.norm(right_eye_center - left_eye_center)\n","\n","    if eye_distance < 1e-6:\n","        return None\n","\n","    # Yaw proxy:\n","    # compare distance from nose to left eye vs nose to right eye\n","    dist_left = np.linalg.norm(nose_tip - left_eye_center)\n","    dist_right = np.linalg.norm(nose_tip - right_eye_center)\n","    yaw = (dist_left - dist_right) / eye_distance\n","\n","    # Pitch proxy:\n","    # compare nose vertical placement between forehead and chin\n","    face_height = np.linalg.norm(chin - forehead)\n","    if face_height < 1e-6:\n","        return None\n","\n","    pitch = ((nose_tip[1] - forehead[1]) / face_height)\n","\n","    return {\n","        \"yaw\": float(yaw),\n","        \"pitch\": float(pitch),\n","        \"eye_distance\": float(eye_distance)\n","    }\n","\n","def evaluate_liveness_challenge(challenge, pose1, pose2):\n","    \"\"\"\n","    Returns pass/fail and score interpretation.\n","    \"\"\"\n","    if pose1 is None or pose2 is None:\n","        return False, \"pose_estimation_failed\", None\n","\n","    yaw_delta = pose2[\"yaw\"] - pose1[\"yaw\"]\n","    pitch_delta = pose2[\"pitch\"] - pose1[\"pitch\"]\n","\n","    if challenge == \"LOOK_LEFT\":\n","        passed = yaw_delta < -YAW_THRESHOLD\n","        score = yaw_delta\n","        note = \"expected more negative yaw change\"\n","    elif challenge == \"LOOK_RIGHT\":\n","        passed = yaw_delta > YAW_THRESHOLD\n","        score = yaw_delta\n","        note = \"expected more positive yaw change\"\n","    elif challenge == \"LOOK_UP\":\n","        # when looking up, nose tends to move upward relative to face shape,\n","        # so pitch proxy typically decreases\n","        passed = pitch_delta < -PITCH_UP_THRESHOLD\n","        score = pitch_delta\n","        note = \"expected more negative pitch change\"\n","    else:\n","        passed = False\n","        score = None\n","        note = \"unknown challenge\"\n","\n","    return passed, note, {\n","        \"yaw_delta\": float(yaw_delta),\n","        \"pitch_delta\": float(pitch_delta),\n","        \"raw_score\": float(score) if score is not None else None\n","    }\n","\n","def derive_image2_path(image1_path):\n","    \"\"\"\n","    Converts:\n","      ...round_001_img1.jpg -> ...round_001_img2.jpg\n","    \"\"\"\n","    return image1_path.replace(\"_img1.\", \"_img2.\")\n","\n","# -----------------------------\n","# 5. Load test rounds\n","# -----------------------------\n","with open(JSON_PATH, \"r\") as f:\n","    rounds = json.load(f)\n","\n","all_results = []\n","\n","for item in rounds:\n","    round_num = item.get(\"round\")\n","    challenge = item.get(\"challenge\")\n","    image1_path = item.get(\"image_1\")\n","\n","    if not image1_path:\n","        all_results.append({\n","            \"round\": round_num,\n","            \"challenge\": challenge,\n","            \"image_1\": None,\n","            \"image_2\": None,\n","            \"face_detected_img1\": False,\n","            \"face_detected_img2\": False,\n","            \"liveness_pass\": False,\n","            \"reason\": \"missing_image_1_path\",\n","            \"yaw_delta\": None,\n","            \"pitch_delta\": None\n","        })\n","        continue\n","\n","    image2_path = derive_image2_path(image1_path)\n","\n","    img1 = load_image_rgb(image1_path)\n","    img2 = load_image_rgb(image2_path)\n","\n","    if img1 is None or img2 is None:\n","        all_results.append({\n","            \"round\": round_num,\n","            \"challenge\": challenge,\n","            \"image_1\": image1_path,\n","            \"image_2\": image2_path,\n","            \"face_detected_img1\": False,\n","            \"face_detected_img2\": False,\n","            \"liveness_pass\": False,\n","            \"reason\": \"could_not_read_image\",\n","            \"yaw_delta\": None,\n","            \"pitch_delta\": None\n","        })\n","        continue\n","\n","    lm1 = get_landmarks(img1)\n","    lm2 = get_landmarks(img2)\n","\n","    face1 = lm1 is not None\n","    face2 = lm2 is not None\n","\n","    if REQUIRE_FACE_IN_BOTH and (not face1 or not face2):\n","        all_results.append({\n","            \"round\": round_num,\n","            \"challenge\": challenge,\n","            \"image_1\": image1_path,\n","            \"image_2\": image2_path,\n","            \"face_detected_img1\": face1,\n","            \"face_detected_img2\": face2,\n","            \"liveness_pass\": False,\n","            \"reason\": \"no_face_detected_in_one_or_both_images\",\n","            \"yaw_delta\": None,\n","            \"pitch_delta\": None\n","        })\n","        continue\n","\n","    pose1 = estimate_pose_features(lm1) if lm1 is not None else None\n","    pose2 = estimate_pose_features(lm2) if lm2 is not None else None\n","\n","    passed, note, metrics = evaluate_liveness_challenge(challenge, pose1, pose2)\n","\n","    all_results.append({\n","        \"round\": round_num,\n","        \"challenge\": challenge,\n","        \"image_1\": image1_path,\n","        \"image_2\": image2_path,\n","        \"face_detected_img1\": face1,\n","        \"face_detected_img2\": face2,\n","        \"liveness_pass\": bool(passed),\n","        \"reason\": \"ok\" if passed else note,\n","        \"yaw_delta\": metrics[\"yaw_delta\"] if metrics else None,\n","        \"pitch_delta\": metrics[\"pitch_delta\"] if metrics else None,\n","        \"raw_score\": metrics[\"raw_score\"] if metrics else None\n","    })\n","\n","# -----------------------------\n","# 6. Save outputs\n","# -----------------------------\n","df = pd.DataFrame(all_results)\n","df.to_csv(OUTPUT_CSV, index=False)\n","\n","with open(OUTPUT_JSON, \"w\") as f:\n","    json.dump(all_results, f, indent=2)\n","\n","# -----------------------------\n","# 7. Print summary\n","# -----------------------------\n","total_rounds = len(df)\n","passed_rounds = int(df[\"liveness_pass\"].sum())\n","failed_rounds = total_rounds - passed_rounds\n","pass_rate = (passed_rounds / total_rounds * 100) if total_rounds > 0 else 0\n","\n","print(\"========== LIVENESS SUMMARY ==========\")\n","print(f\"JSON file: {JSON_PATH}\")\n","print(f\"Total rounds: {total_rounds}\")\n","print(f\"Passed: {passed_rounds}\")\n","print(f\"Failed: {failed_rounds}\")\n","print(f\"Pass rate: {pass_rate:.2f}%\")\n","print()\n","print(\"By challenge:\")\n","print(df.groupby(\"challenge\")[\"liveness_pass\"].agg([\"count\", \"sum\"]))\n","\n","print()\n","print(f\"Saved CSV to:  {OUTPUT_CSV}\")\n","print(f\"Saved JSON to: {OUTPUT_JSON}\")\n","\n","display(df.head(10))"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":712},"id":"abJJMum5nEzL","executionInfo":{"status":"ok","timestamp":1776416039423,"user_tz":240,"elapsed":70410,"user":{"displayName":"Jeremiah Poggers","userId":"12070734939999147503"}},"outputId":"ae0cf1b4-8631-4470-d88e-a495ab5e8392"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Drive already mounted at /content/drive; to attempt to forcibly remount, call drive.mount(\"/content/drive\", force_remount=True).\n"]},{"output_type":"stream","name":"stderr","text":["/usr/local/lib/python3.12/dist-packages/google/protobuf/symbol_database.py:55: UserWarning: SymbolDatabase.GetPrototype() is deprecated. Please use message_factory.GetMessageClass() instead. SymbolDatabase.GetPrototype() will be removed soon.\n","  warnings.warn('SymbolDatabase.GetPrototype() is deprecated. Please '\n"]},{"output_type":"stream","name":"stdout","text":["========== LIVENESS SUMMARY ==========\n","JSON file: /content/drive/MyDrive/Capstone/dataset/dark/facenet_results_dark.json\n","Total rounds: 50\n","Passed: 49\n","Failed: 1\n","Pass rate: 98.00%\n","\n","By challenge:\n","            count  sum\